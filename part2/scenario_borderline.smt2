; ============================================================
; Part 2 — Scenario 3: Borderline / Ambiguous Case
; ============================================================
;
; Scenario Description (generated by Claude):
; --------------------------------------------
; Taxpayer:  Carol (age 50, U.S. citizen, not a dependent of anyone else)
; Potential Dependent: Maya (age 22, Carol's daughter)
;
; Facts:
;   - Maya is Carol's biological daughter ✓
;   - Maya lives with Carol for exactly 7 months ✓ (just over 6)
;   - Maya is 22 years old AND a full-time student ✓ (under 24 + student)
;   - Maya provides EXACTLY 50% of her own support (borderline!)
;     §152(c)(1)(D) says "not MORE than half" → 50% = not more than 50% → PASSES (barely)
;   - Carol provides exactly 50% of Maya's total support
;     §152(d)(1)(C) says "more than half" → 50% is NOT more than 50% → FAILS for QR
;   - Maya's gross income: $4,600 (under $4,700 exemption) ✓
;   - Maya did not file a joint return ✓
;   - Maya is a U.S. citizen ✓
;
; Why Borderline?
;   - As Qualifying Child: PASSES — self_support = 0.5 satisfies "not MORE than half"
;   - As Qualifying Relative: the support ratio test uses "more than half" (strict >0.5),
;     so 0.5 from taxpayer would FAIL the QR support test
;   - The exact 50% boundary exposes the asymmetry between QC and QR support rules:
;     QC uses ≤ 0.5 (not more than half) while QR uses > 0.5 (more than half)
;
; Expected Result: Maya IS a qualifying child (barely), thus IS a dependent.
;   The borderline nature: if Carol's support were 49% and Maya's were 51%,
;   Maya would fail BOTH tests and not be a dependent at all.
; ============================================================

; --- Variable declarations ---
(declare-const is_child_or_descendant Bool)
(declare-const is_sibling_or_descendant Bool)
(declare-const months_same_abode Int)
(declare-const age Int)
(declare-const is_full_time_student Bool)
(declare-const is_permanently_disabled Bool)
(declare-const d_self_support_ratio Real)
(declare-const filed_joint_return Bool)
(declare-const filed_joint_only_for_refund Bool)
(declare-const is_us_citizen_or_national Bool)
(declare-const is_resident_us_canada_mexico Bool)
(declare-const taxpayer_is_dependent_of_another Bool)
(declare-const is_specified_relative Bool)
(declare-const is_household_member_full_year Bool)
(declare-const gross_income Int)
(declare-const exemption_amount Int)
(declare-const taxpayer_support_ratio Real)
(declare-const is_qc_of_any_taxpayer Bool)

; --- §152 rule definitions ---
(define-fun qc_relationship_test () Bool
  (or is_child_or_descendant is_sibling_or_descendant))
(define-fun qc_residence_test () Bool
  (> months_same_abode 6))
(define-fun qc_age_test () Bool
  (or (< age 19)
      (and (< age 24) is_full_time_student)
      is_permanently_disabled))
(define-fun qc_support_test () Bool
  (not (> d_self_support_ratio (/ 1.0 2.0))))
(define-fun no_joint_return_test () Bool
  (or (not filed_joint_return) filed_joint_only_for_refund))
(define-fun is_qualifying_child () Bool
  (and qc_relationship_test qc_residence_test qc_age_test
       qc_support_test no_joint_return_test))

(define-fun qr_not_qc_test () Bool
  (not is_qc_of_any_taxpayer))
(define-fun qr_relationship_test () Bool
  (or is_specified_relative is_household_member_full_year))
(define-fun qr_income_test () Bool
  (< gross_income exemption_amount))
(define-fun qr_support_test () Bool
  (> taxpayer_support_ratio (/ 1.0 2.0)))
(define-fun is_qualifying_relative () Bool
  (and qr_not_qc_test qr_relationship_test qr_income_test qr_support_test))

(define-fun passes_exceptions () Bool
  (and no_joint_return_test
       (or is_us_citizen_or_national is_resident_us_canada_mexico)
       (not taxpayer_is_dependent_of_another)))

(define-fun is_dependent () Bool
  (and (or is_qualifying_child is_qualifying_relative)
       passes_exceptions))

; --- Scenario-specific facts (Maya's case) ---
(assert (= exemption_amount 4700))
(assert (= is_child_or_descendant true))           ; biological daughter
(assert (= is_sibling_or_descendant false))
(assert (= months_same_abode 7))                   ; exactly 7 months (just over 6)
(assert (= age 22))                                ; age 22
(assert (= is_full_time_student true))             ; full-time student
(assert (= is_permanently_disabled false))
(assert (= d_self_support_ratio (/ 1.0 2.0)))      ; EXACTLY 50% self-support (borderline)
(assert (= filed_joint_return false))
(assert (= filed_joint_only_for_refund false))
(assert (= is_us_citizen_or_national true))
(assert (= is_resident_us_canada_mexico false))
(assert (= taxpayer_is_dependent_of_another false))
(assert (= is_specified_relative true))
(assert (= is_household_member_full_year false))   ; only 7 months, not full year
(assert (= gross_income 4600))                     ; $4,600 (under $4,700 limit)
(assert (= taxpayer_support_ratio (/ 1.0 2.0)))    ; Carol provides exactly 50%
(assert (= is_qc_of_any_taxpayer false))

; --- Verify borderline behavior ---
; Check 1: Is Maya a dependent? (expect sat — she passes as qualifying child)
(check-sat)
(get-value (is_qualifying_child))
(get-value (qc_support_test))      ; key borderline test: d_self_support = 0.5, should be true
(get-value (is_qualifying_relative))
(get-value (qr_support_test))      ; key borderline test: taxpayer_support = 0.5, should be false
(get-value (is_dependent))
